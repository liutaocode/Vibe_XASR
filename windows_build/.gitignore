# Build output
bin/
obj/
dist/

# Installer artifacts (staged payload + built package — large, regenerated by build-installer.ps1)
installer/payload/
installer/*.msi
installer/*.wixpdb

# Models are fetched from HuggingFace, never committed
models/
*.onnx
tokens.txt

# EdDSA auto-update SIGNING KEY — secret, never commit. Back this up safely:
# losing it means you can't sign future updates; leaking it lets others sign malicious ones.
installer/eddsa_private.key
*.key

# IDE / OS cruft
.vs/
*.user
.DS_Store
