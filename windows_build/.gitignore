# Build output
bin/
obj/
dist/

# Installer artifacts (staged payload + built package — large, regenerated by build-installer.ps1)
installer/payload/
installer/*.msi
installer/*.wixpdb

# ASR model payload is fetched from HuggingFace / staged at build time, never committed.
# (payload/ + dist/ above already cover the model dirs. Do NOT add a bare `models/` rule —
#  it also matches the C# source dir src/VibeXASR.Windows/Models/ and would drop ModelPaths.cs.)
*.onnx
tokens.txt
bpe.vocab

# EdDSA auto-update SIGNING KEY — secret, never commit. Back this up safely:
# losing it means you can't sign future updates; leaking it lets others sign malicious ones.
installer/eddsa_private.key
*.key

# FireRedVAD native build artifacts. The shipped firered_vad.dll + its sources/headers/build
# script ARE committed; these (objects, generated import lib, copied onnxruntime.dll) and the
# model copy (sourced from macos_build at packaging time) are not.
third_party/firered/build/
third_party/firered/model/

# IDE / OS cruft
.vs/
*.user
.DS_Store
